{
  "name": "holder-cool",
  "version": "1.0.5",
  "appId": "com.hes.holder.electron-oa",
  "description": "Electron + React + TypeScript + Ant Design 桌面应用",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "pnpm run build:electron && concurrently \"pnpm run dev:shell\" \"pnpm run dev:electron:watch\" \"wait-on http://localhost:5173 -t 30000 && pnpm run dev:electron:start\"",
    "dev:shell": "pnpm --filter @holder/shell dev",
    "dev:electron:watch": "pnpm --filter @holder/electron dev",
    "dev:electron:start": "cross-env NODE_ENV=development electron .",
    "dev:electron": "pnpm run build:electron && cross-env NODE_ENV=development electron .",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=@holder/shared-types --filter=@holder/ipc-bridge --filter=@holder/api --filter=@holder/ui",
    "build:shell": "pnpm --filter @holder/shell build",
    "build:renderer": "pnpm --filter @holder/shell build",
    "build:re": "pnpm run build:renderer:re && pnpm run build:electron",
    "build:renderer:re": "pnpm --filter @holder/shell build:re",
    "build:prod": "pnpm run build:renderer:prod && pnpm run build:electron",
    "build:renderer:prod": "pnpm --filter @holder/shell build",
    "build:electron": "pnpm --filter @holder/electron build",
    "preview": "pnpm --filter @holder/shell preview",
    "pack": "node scripts/build-with-version.js",
    "dist": "pnpm run build:prod && node scripts/build-with-version.js",
    "dist:re": "pnpm run build:re && node scripts/build-with-version.js",
    "dist:win32": "pnpm run build:prod && node scripts/build-with-version.js --win --ia32",
    "dist:win64": "pnpm run build:prod && node scripts/build-with-version.js --win --x64",
    "dist:win": "pnpm run build:prod && node scripts/build-with-version.js --win --x64 --ia32",
    "dist:re:win32": "pnpm run build:re && node scripts/build-with-version.js --win --ia32",
    "dist:re:win64": "pnpm run build:re && node scripts/build-with-version.js --win --x64",
    "dist:re:win": "pnpm run build:re && node scripts/build-with-version.js --win --x64 --ia32",
    "lint": "biome check .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "clean": "turbo run clean"
  },
  "keywords": ["electron", "react", "typescript", "antd"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons": "^6.1.0",
    "@reduxjs/toolkit": "^2.11.2",
    "antd": "^6.1.1",
    "axios": "^1.13.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.11.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-react": "^4.7.0",
    "react-refresh": "^0.17.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.7",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "less": "^4.5.1",
    "terser": "^5.44.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1",
    "turbo": "^2.3.3",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "com.yourcompany.holder",
    "productName": "holder",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "package.json",
      "!**/node_modules/**/*",
      "!**/*.map",
      "!**/.DS_Store",
      "!**/Thumbs.db",
      "!**/.vscode/**/*",
      "!**/.idea/**/*",
      "!**/src/**/*",
      "!**/docs/**/*",
      "!**/scripts/**/*",
      "!**/*.md",
      "!**/.git/**/*",
      "!**/.eslintrc.*",
      "!**/.prettierrc*",
      "!**/release/**/*",
      "!**/electron-builder.temp.json",
      "!**/tsconfig*.json",
      "!**/vite.config.ts",
      "!**/.gitignore",
      "!**/README.md",
      "!**/.prettierrc",
      "!**/.eslintrc.cjs"
    ],
    "extraFiles": [],
    "extraResources": [
      {
        "from": "build/icon.ico",
        "to": "build/icon.ico"
      },
      {
        "from": "build/icon.png",
        "to": "build/icon.png"
      }
    ],
    "asar": true,
    "asarUnpack": [],
    "compression": "normal",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "holder",
      "installerLanguages": ["zh_CN"],
      "displayLanguageSelector": false,
      "multiLanguageInstaller": false,
      "runAfterFinish": true,
      "menuCategory": false,
      "differentialPackage": false
    },
    "mac": {
      "target": ["dmg"]
    },
    "linux": {
      "target": ["AppImage", "deb"]
    }
  },
  "packageManager": "pnpm@9.14.2+sha512.6e2baf77d06b9362294152c851c4f278ede37ab1eba3a55fda317a4a17b209f4dbb973fb250a77abc463a341fcb1f17f17cfa24091c4eb319cda0d9b84278387"
}
