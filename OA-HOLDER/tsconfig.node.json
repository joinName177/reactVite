{
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "skipLibCheck": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "target": "ES2020",
    "lib": ["ES2020"],
    "types": ["node"],
    "outDir": "dist/main",
    "rootDir": "src/main",
    "esModuleInterop": true,
    "tsBuildInfoFile": "dist/main/.tsbuildinfo"
  },
  "include": ["src/main"]
}
