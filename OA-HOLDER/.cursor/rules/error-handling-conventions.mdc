## 异步异常统一处理

### Hook 内的异步操作

异步 hook 必须管理 `loading` 和 `error` 状态，且错误不能静默吞掉：

```typescript
// ✅ 完整的异步状态管理
function useTaskList(filters: ITaskFilters) {
  const [list, setList] = useState<ITask[]>([])
  const [loading, setLoading] = useState(false)
  const [error, setError] = useState<Error | null>(null)

  const fetchList = useCallback(async () => {
    setLoading(true)
    setError(null)
    try {
      const data = await taskApi.list(filters)
      setList(data)
    } catch (err) {
      const error = err instanceof Error ? err : new Error(String(err))
      setError(error)
      // 不要在这里直接 message.error，由调用方决定如何展示
    } finally {
      setLoading(false)
    }
  }, [filters])

  return { list, loading, error, fetchList }
}

// ❌ 静默吞掉错误，用户无感知，调试困难
const fetchList = async () => {
  try {
    const data = await taskApi.list(filters)
    setList(data)
  } catch {
    // 什么都不做
  }
}
```

### 事件处理器中的异步错误

事件处理器（`onClick`、`onSubmit` 等）内的异步错误不会被 Error Boundary 捕获，必须显式 catch：

```typescript
// ✅ 事件处理器必须 try/catch，并给用户可读反馈
const handleSubmit = useCallback(async (values: ILoginFormValues) => {
  try {
    setSubmitting(true)
    await authApi.login(values)
    navigate('/')
  } catch (err) {
    const msg = err instanceof Error ? err.message : t('loginError')
    message.error(msg)
  } finally {
    setSubmitting(false)
  }
}, [navigate, t])

// ❌ 未处理的 Promise rejection 会导致控制台报错，用户无反馈
const handleSubmit = async (values: ILoginFormValues) => {
  await authApi.login(values)   // 失败时静默崩溃
  navigate('/')
}
```

