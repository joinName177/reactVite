# 错误处理规范

## Error Boundary 覆盖策略

React 的 Error Boundary 只能捕获**同步渲染异常**，异步（Promise、setTimeout）和事件处理器中的异常需要另行处理。

### 必须包裹的位置

```tsx
// ✅ 每个业务模块入口包裹独立 ErrorBoundary，防止单模块崩溃影响整体
<ErrorBoundary fallback={<ModuleErrorFallback />}>
  <TaskModule />
</ErrorBoundary>

// ✅ 动态加载（Suspense）必须同时包裹 ErrorBoundary
<ErrorBoundary fallback={<PageErrorFallback />}>
  <Suspense fallback={<LoadingSpinner fullscreen />}>
    <LazyPage />
  </Suspense>
</ErrorBoundary>

// ❌ 整个应用只有一个顶层 ErrorBoundary，单模块异常会导致整页白屏
<ErrorBoundary>
  <App />   {/* 粒度太粗 */}
</ErrorBoundary>
```

### ErrorBoundary 实现规范

```tsx
// ✅ 标准 ErrorBoundary 实现，放在 packages/shared/ui/src/components/error-boundary.tsx
interface IErrorBoundaryProps {
  fallback: React.ReactNode
  children: React.ReactNode
  onError?: (error: Error, info: React.ErrorInfo) => void
}

interface IErrorBoundaryState {
  hasError: boolean
  error: Error | null
}

class ErrorBoundary extends React.Component<IErrorBoundaryProps, IErrorBoundaryState> {
  state: IErrorBoundaryState = { hasError: false, error: null }

  static getDerivedStateFromError(error: Error): IErrorBoundaryState {
    return { hasError: true, error }
  }

  componentDidCatch(error: Error, info: React.ErrorInfo): void {
    this.props.onError?.(error, info)
    // 上报到监控系统
    reportError(error, { componentStack: info.componentStack })
  }

  render() {
    if (this.state.hasError) return this.props.fallback
    return this.props.children
  }
}
```

