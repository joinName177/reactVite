{
  "name": "@holder/build-utils",
  "version": "1.0.0",
  "private": true,
  "description": "Holder 构建工具 - 共享 Vite/TS 配置",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
