{
  "name": "@holder/ipc-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Holder IPC 通讯桥 - 类型安全的 Electron IPC 通讯 SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./main": {
      "types": "./dist/main/index.d.ts",
      "import": "./dist/main/index.js"
    },
    "./renderer": {
      "types": "./dist/renderer/index.d.ts",
      "import": "./dist/renderer/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "@holder/shared-types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "electron": "^39.2.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
