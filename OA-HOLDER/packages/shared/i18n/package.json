{
  "name": "@holder/i18n",
  "version": "1.0.0",
  "private": true,
  "description": "Holder 国际化（i18n）库",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./language": {
      "types": "./dist/language/index.d.ts",
      "import": "./dist/language/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "i18next": "^24.2.3",
    "react-i18next": "^15.7.4"
  },
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "rimraf": "^6.0.1",
    "typescript": "^5.9.3"
  }
}
