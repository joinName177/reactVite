{
  "semi": false,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "trailingComma": "none",
  "bracketSpacing": true,
  "arrowParens": "avoid",
  "endOfLine": "lf",
  "jsxSingleQuote": true,
  "singleAttributePerLine": false,
  "jsxBracketSameLine": false,
  "htmlWhitespaceSensitivity": "css",
  "bracketSameLine": false
}
